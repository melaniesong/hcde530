# Copy this file to `.env` in the same folder as `fetch_met_museum_objects.py`.
# The Met Collection API does not require an API key for these calls.
#
# MET_SEARCH_QUERY=sunflower
# MET_MAX_OBJECTS=40
#
# If you see HTTP 403, slow down requests (seconds between each object):
# MET_REQUEST_DELAY_SEC=0.6
